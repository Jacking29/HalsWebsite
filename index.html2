<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hals Craft – Flowers • Bouquets • Crafts</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1a2b5e;
    --gold: #c9953a;
    --pink: #e8527a;
    --cream: #fdf6ee;
    --deep: #0e1a3d;
    --white: #ffffff;
    --light-pink: #fde8ef;
    --light-navy: #e8edf8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--cream);
    color: #333;
    overflow-x: hidden;
  }

  /* ── FLOATING PETALS BACKGROUND ── */
  .petals-bg {
    position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden;
  }
  .petal {
    position: absolute;
    width: 10px; height: 10px;
    border-radius: 50% 0 50% 0;
    opacity: 0.15;
    animation: floatPetal linear infinite;
  }
  @keyframes floatPetal {
    0%   { transform: translateY(-20px) rotate(0deg); opacity: 0; }
    10%  { opacity: 0.2; }
    90%  { opacity: 0.15; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 5%;
    background: rgba(253,246,238,0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201,149,58,0.2);
    transition: box-shadow 0.3s;
  }
  nav.scrolled { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
  .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .nav-logo img { height: 44px; width: auto; border-radius: 50%; }
  .nav-brand { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 700; color: var(--navy); line-height: 1.1; }
  .nav-brand span { display: block; font-size: 0.65rem; font-weight: 400; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; font-family: 'Nunito', sans-serif; }
  .nav-links { display: flex; gap: 28px; list-style: none; }
  .nav-links a { text-decoration: none; color: var(--navy); font-weight: 600; font-size: 0.88rem; letter-spacing: 0.5px; position: relative; }
  .nav-links a::after { content: ''; position: absolute; bottom: -3px; left: 0; width: 0; height: 2px; background: var(--gold); transition: width 0.3s; }
  .nav-links a:hover::after { width: 100%; }
  .nav-cta {
    background: var(--navy); color: var(--white); border: none; padding: 10px 20px;
    border-radius: 50px; font-family: 'Nunito', sans-serif; font-weight: 700;
    font-size: 0.85rem; cursor: pointer; text-decoration: none; transition: all 0.3s;
    display: flex; align-items: center; gap: 6px;
  }
  .nav-cta:hover { background: var(--gold); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(201,149,58,0.4); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center; gap: 0;
    padding: 100px 5% 60px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; right: -5%; top: -10%; width: 60%; height: 120%;
    background: radial-gradient(ellipse at center, var(--light-navy) 0%, var(--light-pink) 50%, transparent 80%);
    border-radius: 50%;
    z-index: -1;
  }
  .hero-text { z-index: 1; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--light-pink); border: 1px solid rgba(232,82,122,0.3);
    padding: 6px 16px; border-radius: 50px; margin-bottom: 20px;
    font-size: 0.78rem; font-weight: 700; color: var(--pink); letter-spacing: 1px; text-transform: uppercase;
    animation: fadeInUp 0.6s ease both;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 700; line-height: 1.1; color: var(--navy);
    margin-bottom: 16px;
    animation: fadeInUp 0.6s 0.1s ease both;
  }
  .hero-title em { color: var(--gold); font-style: italic; }
  .hero-subtitle {
    font-size: 1.05rem; color: #555; line-height: 1.7; max-width: 440px;
    margin-bottom: 36px;
    animation: fadeInUp 0.6s 0.2s ease both;
  }
  .hero-buttons {
    display: flex; gap: 14px; flex-wrap: wrap;
    animation: fadeInUp 0.6s 0.3s ease both;
  }
  .btn-primary {
    background: var(--navy); color: white; padding: 14px 28px;
    border-radius: 50px; font-weight: 700; font-size: 0.95rem;
    text-decoration: none; transition: all 0.3s; display: flex; align-items: center; gap: 8px;
    box-shadow: 0 8px 24px rgba(26,43,94,0.3);
  }
  .btn-primary:hover { background: var(--deep); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(26,43,94,0.4); }
  .btn-secondary {
    background: transparent; color: var(--pink); padding: 14px 28px;
    border: 2px solid var(--pink); border-radius: 50px; font-weight: 700; font-size: 0.95rem;
    text-decoration: none; transition: all 0.3s; display: flex; align-items: center; gap: 8px;
  }
  .btn-secondary:hover { background: var(--pink); color: white; transform: translateY(-2px); }

  .hero-images {
    position: relative; display: flex; align-items: center; justify-content: center;
    animation: fadeInRight 0.8s 0.2s ease both;
  }
  .hero-main-img {
    width: 420px; height: 520px; object-fit: cover;
    border-radius: 60% 40% 60% 40% / 50% 50% 50% 50%;
    box-shadow: 0 30px 60px rgba(0,0,0,0.2);
    transition: transform 0.4s ease;
  }
  .hero-main-img:hover { transform: scale(1.03) rotate(-1deg); }
  .hero-float-img {
    position: absolute; width: 200px; height: 220px; object-fit: cover;
    border-radius: 50% 40% 50% 40% / 40% 50% 40% 50%;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    border: 4px solid white;
    bottom: 40px; left: -30px;
    animation: floatImage 4s ease-in-out infinite;
  }
  @keyframes floatImage { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  .hero-tag {
    position: absolute; top: 60px; right: -10px;
    background: white; padding: 12px 18px; border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    display: flex; align-items: center; gap: 8px;
    animation: floatTag 3s ease-in-out infinite;
  }
  @keyframes floatTag { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .hero-tag .tag-text { font-size: 0.78rem; font-weight: 700; color: var(--navy); }
  .hero-tag .tag-emoji { font-size: 1.4rem; }

  .hero-stats {
    display: flex; gap: 32px; margin-top: 40px;
    animation: fadeInUp 0.6s 0.4s ease both;
  }
  .stat { text-align: center; }
  .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 700; color: var(--navy); line-height: 1; }
  .stat-label { font-size: 0.72rem; color: #888; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; }

  /* ── FEATURES STRIP ── */
  .features-strip {
    background: var(--navy);
    padding: 20px 5%;
    display: flex; gap: 0; overflow-x: auto;
    position: relative; z-index: 1;
  }
  .feature-item {
    flex: 1; min-width: 180px; display: flex; align-items: center; gap: 10px;
    padding: 8px 20px; border-right: 1px solid rgba(255,255,255,0.15);
    white-space: nowrap;
  }
  .feature-item:last-child { border-right: none; }
  .feature-item .fi-icon { font-size: 1.4rem; }
  .feature-item .fi-text { font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.9); }

  /* ── SECTION COMMONS ── */
  section { position: relative; z-index: 1; }
  .section-header { text-align: center; margin-bottom: 50px; }
  .section-tag {
    display: inline-block; background: var(--light-pink); color: var(--pink);
    font-size: 0.72rem; font-weight: 800; letter-spacing: 2px; text-transform: uppercase;
    padding: 5px 16px; border-radius: 50px; margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 700; color: var(--navy); line-height: 1.2;
  }
  .section-title em { color: var(--gold); font-style: italic; }
  .section-desc { color: #666; font-size: 1rem; margin-top: 12px; max-width: 500px; margin-left: auto; margin-right: auto; line-height: 1.7; }

  /* ── PRODUCTS ── */
  .products { padding: 90px 5%; background: var(--cream); }
  .products-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 28px;
  }
  .product-card {
    background: white; border-radius: 24px; overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transition: all 0.4s ease; cursor: pointer; position: relative;
  }
  .product-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
  }
  .product-card .badge {
    position: absolute; top: 16px; left: 16px; z-index: 2;
    background: var(--gold); color: white; padding: 4px 12px; border-radius: 50px;
    font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;
  }
  .product-img { width: 100%; height: 300px; object-fit: cover; transition: transform 0.4s; }
  .product-card:hover .product-img { transform: scale(1.05); }
  .product-info { padding: 24px; }
  .product-name { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .product-desc { font-size: 0.88rem; color: #777; line-height: 1.6; margin-bottom: 16px; }
  .product-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 18px; }
  .product-tag {
    background: var(--light-navy); color: var(--navy); padding: 4px 10px;
    border-radius: 50px; font-size: 0.72rem; font-weight: 700;
  }
  .product-tag.pink { background: var(--light-pink); color: var(--pink); }
  .product-cta {
    width: 100%; background: var(--navy); color: white; border: none;
    padding: 12px; border-radius: 12px; font-family: 'Nunito', sans-serif;
    font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.3s;
    text-align: center; text-decoration: none; display: block;
  }
  .product-cta:hover { background: var(--gold); }

  /* ── SIZES ── */
  .sizes { padding: 90px 5%; background: linear-gradient(135deg, var(--light-navy) 0%, var(--light-pink) 100%); }
  .sizes-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px; }
  .size-card {
    background: white; border-radius: 24px; padding: 32px 24px; text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06); transition: all 0.3s;
    border: 2px solid transparent;
  }
  .size-card:hover { border-color: var(--gold); transform: translateY(-6px); }
  .size-card.featured { background: var(--navy); border-color: var(--gold); }
  .size-card.featured * { color: white !important; }
  .size-icon { font-size: 3rem; margin-bottom: 16px; display: block; }
  .size-name { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 700; color: var(--navy); }
  .size-stems { font-size: 0.88rem; color: var(--gold); font-weight: 800; margin: 8px 0 16px; letter-spacing: 1px; }
  .size-features { list-style: none; text-align: left; }
  .size-features li { font-size: 0.82rem; color: #666; padding: 5px 0; display: flex; align-items: center; gap: 6px; }
  .size-features li::before { content: '✓'; color: var(--gold); font-weight: 800; }

  /* ── WHY US ── */
  .whyus { padding: 90px 5%; background: var(--cream); }
  .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .why-img-wrap { position: relative; }
  .why-img {
    width: 100%; height: 500px; object-fit: cover;
    border-radius: 40px 20px 40px 20px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.15);
  }
  .why-float {
    position: absolute; bottom: -20px; right: -20px;
    background: var(--gold); color: white; padding: 20px 24px;
    border-radius: 20px; text-align: center; box-shadow: 0 10px 30px rgba(201,149,58,0.4);
  }
  .why-float .wf-num { font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; font-weight: 700; line-height: 1; }
  .why-float .wf-label { font-size: 0.72rem; font-weight: 700; opacity: 0.9; letter-spacing: 1px; }
  .why-items { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; }
  .why-item {
    background: white; padding: 20px; border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    display: flex; align-items: flex-start; gap: 14px;
  }
  .why-icon { font-size: 1.8rem; flex-shrink: 0; }
  .why-item h4 { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
  .why-item p { font-size: 0.8rem; color: #777; line-height: 1.5; }

  /* ── GALLERY / COLORS ── */
  .gallery { padding: 90px 5%; background: var(--navy); }
  .gallery .section-tag { background: rgba(201,149,58,0.2); color: var(--gold); }
  .gallery .section-title { color: white; }
  .gallery .section-desc { color: rgba(255,255,255,0.6); }
  .gallery-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  .gallery-item {
    border-radius: 20px; overflow: hidden; position: relative; cursor: pointer;
    aspect-ratio: 3/4;
  }
  .gallery-item:nth-child(2) { aspect-ratio: 3/5; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .gallery-item:hover img { transform: scale(1.08); }
  .gallery-item .overlay {
    position: absolute; inset: 0; background: linear-gradient(to top, rgba(14,26,61,0.8) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.3s; display: flex; align-items: flex-end; padding: 20px;
  }
  .gallery-item:hover .overlay { opacity: 1; }
  .overlay-text { color: white; font-weight: 700; font-size: 0.9rem; }

  /* ── PROCESS ── */
  .process { padding: 90px 5%; background: var(--cream); }
  .process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; position: relative; }
  .process-steps::before {
    content: ''; position: absolute; top: 36px; left: 12.5%; right: 12.5%;
    height: 2px; background: linear-gradient(to right, var(--light-pink), var(--gold), var(--light-navy));
    z-index: 0;
  }
  .step { text-align: center; position: relative; z-index: 1; }
  .step-num {
    width: 72px; height: 72px; border-radius: 50%;
    background: var(--navy); color: white; display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 700;
    margin: 0 auto 16px; box-shadow: 0 8px 24px rgba(26,43,94,0.3);
    border: 4px solid var(--cream);
  }
  .step-icon { font-size: 1.6rem; position: absolute; top: 14px; left: 50%; transform: translateX(-50%); }
  .step h4 { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
  .step p { font-size: 0.8rem; color: #777; line-height: 1.5; }

  /* ── CTA SECTION ── */
  .cta-section {
    padding: 90px 5%;
    background: linear-gradient(135deg, var(--navy) 0%, var(--deep) 100%);
    text-align: center; position: relative; overflow: hidden;
  }
  .cta-section::before {
    content: '🌸';
    position: absolute; font-size: 300px; opacity: 0.04;
    top: -60px; right: -60px; line-height: 1;
  }
  .cta-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: white; margin-bottom: 16px;
  }
  .cta-section h2 em { color: var(--gold); }
  .cta-section p { color: rgba(255,255,255,0.7); font-size: 1rem; margin-bottom: 36px; max-width: 480px; margin-left: auto; margin-right: auto; }
  .cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-wa {
    background: #25d366; color: white; padding: 16px 32px;
    border-radius: 50px; font-weight: 800; font-size: 1rem;
    text-decoration: none; display: flex; align-items: center; gap: 10px;
    transition: all 0.3s; box-shadow: 0 8px 24px rgba(37,211,102,0.4);
  }
  .btn-wa:hover { background: #1ebe5d; transform: translateY(-3px); box-shadow: 0 12px 32px rgba(37,211,102,0.5); }
  .btn-ig {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: white; padding: 16px 32px;
    border-radius: 50px; font-weight: 800; font-size: 1rem;
    text-decoration: none; display: flex; align-items: center; gap: 10px;
    transition: all 0.3s; box-shadow: 0 8px 24px rgba(220,39,67,0.3);
  }
  .btn-ig:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(220,39,67,0.4); }

  /* ── FOOTER ── */
  footer {
    background: var(--deep); padding: 40px 5% 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .footer-content {
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px;
    margin-bottom: 24px;
  }
  .footer-logo { display: flex; align-items: center; gap: 12px; }
  .footer-logo img { height: 50px; border-radius: 50%; }
  .footer-brand { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 700; color: white; }
  .footer-brand span { display: block; font-size: 0.65rem; color: var(--gold); letter-spacing: 2px; font-family: 'Nunito'; }
  .footer-links { display: flex; gap: 20px; list-style: none; }
  .footer-links a { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
  .footer-links a:hover { color: var(--gold); }
  .footer-socials { display: flex; gap: 12px; }
  .social-btn {
    width: 40px; height: 40px; border-radius: 50%;
    background: rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center;
    text-decoration: none; font-size: 1.1rem; transition: all 0.3s;
  }
  .social-btn:hover { background: var(--gold); transform: translateY(-2px); }
  .footer-copy { text-align: center; color: rgba(255,255,255,0.3); font-size: 0.78rem; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.06); }

  /* ── ANIMATIONS ── */
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeInRight { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }
  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; padding-top: 120px; }
    .hero-images { order: -1; }
    .hero-main-img { width: 300px; height: 360px; }
    .why-grid, .why-items { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: 1fr 1fr; }
    .process-steps { grid-template-columns: 1fr 1fr; }
    .process-steps::before { display: none; }
    .nav-links { display: none; }
  }
</style>
</head>
<body>

<!-- Floating petals -->
<div class="petals-bg" id="petals"></div>

<!-- NAV -->
<nav id="navbar">
  <a href="#" class="nav-logo">
    <img src="data:image/jpeg;base64," alt="Hals Craft Logo">
    <div class="nav-brand">
      Hals Craft
      <span>Flowers • Bouquets • Crafts</span>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="#produk">Produk</a></li>
    <li><a href="#ukuran">Ukuran</a></li>
    <li><a href="#galeri">Galeri</a></li>
    <li><a href="#proses">Proses</a></li>
  </ul>
  <a href="https://wa.me/6285117454646?text=Halo%20Hals%20Craft!%20Saya%20mau%20pesan%20buket%20nih%20🌸" target="_blank" class="nav-cta">
    <span>💬</span> Pesan Sekarang
  </a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-text">
    <div class="hero-badge">✨ Handmade with Love</div>
    <h1 class="hero-title">
      Buket Bunga<br>
      <em>Cantik & Awet</em><br>
      untuk Semua Momen
    </h1>
    <p class="hero-subtitle">
      Buket satin handmade dengan LED fairy lights & hiasan kupu emas.
      Tidak layu, estetik, dan bisa custom warna sesuai keinginanmu! 🦋
    </p>
    <div class="hero-buttons">
      <a href="https://wa.me/6285117454646?text=Halo%20Hals%20Craft!%20Saya%20mau%20pesan%20buket%20nih%20🌸" target="_blank" class="btn-primary">
        💬 Chat WhatsApp
      </a>
      <a href="https://www.instagram.com/biieee_l?igsh=aWYyb2hrejBxZ2Fo" target="_blank" class="btn-secondary">
        📸 Lihat Instagram
      </a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">100%</div>
